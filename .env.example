# ============================================
# ClearFund Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================
# PUBLIC VARIABLES (Safe to expose to browser)
# ============================================
# These variables use NEXT_PUBLIC_ prefix and are exposed to the client-side

# Web3 & Wallet Integration

NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Smart Contract Integration
NEXT_PUBLIC_CLEARFUND_REGISTRY_ADDRESS=0xDA79ADdD7a2191b8484D1f02E9138625ACbE9Ea8 # Celo Sepolia Testnet

# IPFS Configuration
NEXT_PUBLIC_IPFS_PROVIDER=pinata
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket

# ============================================
# SERVER-SIDE SECRETS (DO NOT use NEXT_PUBLIC_ prefix)
# ============================================
# These variables are server-side only and will NOT be exposed to the browser
# Keep these secure and never commit them to version control

# IPFS Provider Secrets (choose one based on NEXT_PUBLIC_IPFS_PROVIDER)
# Option 1: Pinata (if NEXT_PUBLIC_IPFS_PROVIDER=pinata)
PINATA_JWT=your_pinata_jwt_token

# Option 2: NFT.Storage (if NEXT_PUBLIC_IPFS_PROVIDER=nft-storage)
# NFT_STORAGE_KEY=your_nft_storage_api_token

# ============================================
# DATABASE VARIABLES (Server-side Only)
# ============================================
# DATABASE_URL: PostgreSQL connection string for Supabase (use Transaction pooler, port 6543)
# DIRECT_URL: Direct PostgreSQL connection string for migrations (port 5432)
DATABASE_URL="postgresql://postgres.your_project_ref:your_password@aws-0-your_region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your_project_ref:your_password@aws-0-your_region.pooler.supabase.com:5432/postgres"
